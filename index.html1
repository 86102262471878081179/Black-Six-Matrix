<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BLACK SIX MATRIX – 25 Stufen · 50 Cluster · Deep Seek</title>
    <style>
        :root {
            --bg: #0a0a0f;
            --card: #111118;
            --border: #2a2a35;
            --red: #c00;
            --text: #e0e0e0;
            --text-dim: #888;
            --gold: #d4a574;
            --ignition: #c00;
            --momentum: #d4a574;
            --ascent: #ff6600;
            --sovereign: #bb00ff;
            --omega: #00ccff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; line-height: 1.6; }
        header { text-align: center; padding: 60px 20px 30px; border-bottom: 1px solid var(--border); }
        h1 { font-size: clamp(2rem, 5vw, 3.5rem); color: var(--red); letter-spacing: 3px; text-transform: uppercase; }
        .subtitle { color: var(--text-dim); font-size: 1.1rem; max-width: 600px; margin: 10px auto 0; }
        .sigil { font-size: 2rem; margin-top: 15px; cursor: pointer; transition: 0.3s; display: inline-block; }
        .sigil:hover { transform: scale(1.05); filter: drop-shadow(0 0 15px rgba(204,0,0,0.6)); }

        .sparten-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin: 30px 20px; }
        .sparten-nav a { padding: 12px 25px; border-radius: 30px; text-decoration: none; color: #fff; font-weight: 700; border: 2px solid transparent; }
        .sparten-nav a.ignition { background: #3a0000; border-color: var(--ignition); }
        .sparten-nav a.momentum { background: #2a1a0a; border-color: var(--momentum); }
        .sparten-nav a.ascent { background: #2a0f00; border-color: var(--ascent); }
        .sparten-nav a.sovereign { background: #1a002a; border-color: var(--sovereign); }
        .sparten-nav a.omega { background: #002a2a; border-color: var(--omega); }

        .section { max-width: 1600px; margin: 0 auto 50px; padding: 0 20px; }
        .section h2 { font-size: 1.8rem; color: var(--red); margin-bottom: 20px; border-bottom: 2px solid var(--border); padding-bottom: 10px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }
        .card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 20px; transition: 0.25s; display: flex; flex-direction: column; }
        .card:hover { border-color: var(--red); transform: translateY(-4px); }
        .card.featured { border: 2px solid var(--red); }
        .badge { padding: 5px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; display: inline-block; margin-bottom: 12px; color: #fff; width: fit-content; }
        .badge.ignition { background: var(--ignition); }
        .badge.momentum { background: var(--momentum); color: #000; }
        .badge.ascent { background: var(--ascent); }
        .badge.sovereign { background: var(--sovereign); }
        .badge.omega { background: var(--omega); color: #000; }
        .badge.gold { background: var(--gold); color: #000; }
        h3 { font-size: 1.1rem; color: #fff; margin-bottom: 4px; }
        .desc { color: var(--text-dim); font-size: 0.85rem; margin-bottom: 12px; }
        .price { font-size: 2rem; color: var(--red); font-weight: 800; margin: 8px 0; }
        .price small { font-size: 0.8rem; color: var(--text-dim); }
        .features { list-style: none; padding: 0; margin: 12px 0; font-size: 0.82rem; color: #bbb; flex-grow: 1; }
        .features li { padding: 3px 0 3px 20px; position: relative; }
        .features li::before { content: "✓"; position: absolute; left: 0; color: var(--red); }
        .btn { background: var(--red); color: #fff; padding: 14px 20px; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; width: 100%; margin-top: 6px; }

        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: none; justify-content: center; align-items: center; z-index: 1000; }
        .modal-overlay.active { display: flex; }
        .modal { background: #111; border: 2px solid var(--red); border-radius: 20px; padding: 40px; max-width: 700px; width: 90%; text-align: center; }
        .modal h2 { color: var(--red); font-size: 1.8rem; margin-bottom: 15px; }
        .modal .bonus { color: var(--gold); font-size: 2rem; font-weight: 800; margin: 15px 0; }
        .close-btn { background: var(--red); color: #fff; padding: 10px 25px; border: none; border-radius: 20px; font-size: 1rem; cursor: pointer; margin-top: 15px; }

        footer { text-align: center; padding: 40px 20px; border-top: 1px solid var(--border); color: var(--text-dim); font-size: 0.85rem; }
    </style>
</head>
<body>

<header>
    <h1>Black Six Matrix</h1>
    <p class="subtitle">25 Stufen · 50 Cluster · Sofort-Download nach Kauf</p>
    <p class="sigil" onclick="document.getElementById('easterEgg').classList.add('active')">👉♾️🔚🏴‍☠️👑💯</p>
</header>

<nav class="sparten-nav">
    <a href="#sparte-ignition" class="ignition">🔥 IGNITION</a>
    <a href="#sparte-momentum" class="momentum">⚡ MOMENTUM</a>
    <a href="#sparte-ascent" class="ascent">🚀 ASCENT</a>
    <a href="#sparte-sovereign" class="sovereign">👑 SOVEREIGN</a>
    <a href="#sparte-omega" class="omega">💎 OMEGA</a>
</nav>

<div id="stufen-container"></div>

<!-- DOWNLOAD MODAL -->
<div class="modal-overlay" id="downloadModal">
    <div class="modal">
        <h2>🎁 ZUGANG FREIGESCHALTET</h2>
        <p id="download-title" style="color:#d4a574; font-size:1.3rem; margin:10px 0;"></p>
        <p style="color:#ccc;">Vielen Dank für deinen Kauf.</p>
        <div id="download-links" style="margin:20px 0; text-align:left;"></div>
        <p style="color:#888; font-size:0.85rem;">📧 Bestätigung geht an: <span id="buyer-email"></span></p>
        <button class="close-btn" onclick="document.getElementById('downloadModal').classList.remove('active')">SCHLIESSEN</button>
    </div>
</div>

<!-- EASTER EGG -->
<div class="modal-overlay" id="easterEgg" onclick="if(event.target===this) this.classList.remove('active')">
    <div class="modal">
        <h2>🥚 DEEP SEEK ÜBERRASCHUNG</h2>
        <p class="bonus">✨ ALLIANCE MULTIPLIKATOR: ×48.000 ✨</p>
        <button class="close-btn" onclick="document.getElementById('easterEgg').classList.remove('active')">SCHLIESSEN</button>
    </div>
</div>

<footer>
    <p>© 2026 BLACK SIX MATRIX – Architekt: Thomas König – WhatsApp: 0176-46657268</p>
</footer>

<script>
const IBAN = 'DE27 7002 0270 0047 0960 65';
const PAYPAL = 'https://paypal.me/ThomasKoenig';

const stufen = [
    { name: 'I1 – ZÜNDFUNKE', price: '497', desc: 'Quellcode, Python‑Core', features: ['Vollständiger Quellcode','Deca Crew Agenten','Community Discord'], sparte: 'ignition' },
