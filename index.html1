.iban-box{background:#1a1a1a;padding:15px;border-radius:8px;margin:15px 0;font-size:13px;word-break:break-all;text-align:left}
.paypal-qr{width:140px;height:140px;margin:15px auto;display:block;border-radius:8px;background:#fff;padding:10px}
.btn{background:#c00;color:#fff;padding:14px 25px;border:none;border-radius:8px;font-size:16px;font-weight:bold;cursor:pointer;width:100%}
.btn:hover{background:#a00}
.badge{background:#c00;padding:5px 12px;border-radius:20px;font-size:11px;display:inline-block;margin-bottom:10px;font-weight:bold}
</style>
</head>
