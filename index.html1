    { name: 'I3 – FUNKE', price: '990', desc: '+ CLI‑Tool', features: ['Alles aus I2','CLI‑Tool b6','10 Skripte'], sparte: 'ignition' },
    { name: 'I4 – FLAMME', price: '1200', desc: '+ Docker', features: ['Alles aus I3','Docker‑Image','Lokaler Server'], sparte: 'ignition' },
    { name: '🔥 I5 – INFERNO', price: '1500', desc: 'Komplettpaket + 1 Jahr', features: ['Alles aus I4','1 Jahr Updates','iOS‑App'], featured: true, sparte: 'ignition' },
    { name: 'M1 – BOOTCAMP', price: '1250', desc: '4 Wochen Coaching', features: ['4 Live‑Sessions','Zertifikat Operator'], sparte: 'momentum' },
    { name: 'M2 – FORTGESCHRITTEN', price: '2000', desc: '+ Forensik', features: ['Alles aus M1','Forensik‑Workshop'], sparte: 'momentum' },
    { name: 'M3 – AUDIT', price: '2500', desc: 'GL‑1000 Training', features: ['GL‑1000 Zertifizierung','3h Live‑Audit'], sparte: 'momentum' },
    { name: 'M4 – LEGAL‑TECH', price: '3000', desc: 'Judge‑Modul', features: ['5999 Normen','Judge‑Konfiguration'], sparte: 'momentum' },
    { name: '⚡ M5 – MEISTER', price: '3500', desc: 'Alle Coachings', features: ['M1‑M4 kombiniert','Zertifikat Meister'], featured: true, sparte: 'momentum' },
    { name: 'A1 – AUFSTIEG', price: '2500', desc: 'Installation', features: ['Installation','Basis‑Konfiguration'], sparte: 'ascent' },
    { name: 'A2 – ORBIT', price: '4900', desc: '+ Judge Module', features: ['5999 Normen','Beck‑Online'], sparte: 'ascent' },
    { name: 'A3 – BESCHLEUNIGUNG', price: '9900', desc: '+ FPGA', features: ['FPGA‑Modul','Photonischer Compiler'], sparte: 'ascent' },
    { name: 'A4 – MULTIVERSUM', price: '19900', desc: '3 Universen', features: ['Alpha, Beta, Gamma','Qz‑Kette'], sparte: 'ascent' },
    { name: '🚀 A5 – GIPFEL', price: '29900', desc: 'A1‑A4 + Priority', features: ['Alle Profi‑Module','24/7 Support'], featured: true, sparte: 'ascent' },
    { name: 'S1 – ENTERPRISE S', price: '49900/J', desc: 'Bis 50 Nodes', features: ['Vollzugriff','8/5 Support'], sparte: 'sovereign' },
    { name: 'S2 – ENTERPRISE M', price: '249000/J', desc: 'Bis 500 Nodes', features: ['24/7 Support','Dedizierter Ansprechpartner'], sparte: 'sovereign' },
    { name: 'S3 – ENTERPRISE L', price: '990000/J', desc: 'Bis 5.000 Nodes', features: ['Quantum‑Bridge','Source‑Code‑Treuhand'], sparte: 'sovereign' },
    { name: 'S4 – ENTERPRISE XL', price: '1990000/J', desc: 'Bis 50.000 Nodes', features: ['Galactic Router','Operator‑Avatar'], sparte: 'sovereign' },
    { name: '👑 S5 – OMEGA ENTERPRISE', price: '2499000/J', desc: 'Unbegrenzt', features: ['Alle 101.400+ Module','Omega‑Point‑Protokoll'], featured: true, sparte: 'sovereign' },
    { name: 'O1 – AIRGAP', price: '1000', desc: 'Offline‑Archiv', features: ['4,2 GB Paket','SHA‑512'], sparte: 'omega' },
    { name: 'O2 – TRAINING', price: '5000/Tag', desc: '1‑Tages Schulung', features: ['Installation','Zertifizierung'], sparte: 'omega' },
    { name: 'O3 – TREUHAND', price: '100000', desc: 'Notar Hinterlegung', features: ['Vollständiger Quellcode','Notariell gesichert'], sparte: 'omega' },
    { name: 'O4 – INDIVIDUELL', price: '250/h', desc: 'Entwicklung', features: ['Neue Module','API‑Integration'], sparte: 'omega' },
    { name: '💎 O5 – OMEGA‑STEIN', price: '∞', desc: 'Das Vermächtnis', features: ['Alle Rechte','Ewige Updates'], featured: true, sparte: 'omega' }
];

function kaufeJetzt(stufe, preis) {
    const email = prompt(`Für: ${stufe}\nPreis: ${preis}\n\nBitte E-Mail für Lieferung:`);
    if(!email) return;
    window.open(PAYPAL, '_blank');
    
    setTimeout(() => {
        document.getElementById('buyer-email').innerText = email;
        document.getElementById('download-title').innerText = stufe;
        
        let links = `<p style="color:#00ccff;">📧 Wir schicken dir alle Dateien an: ${email}</p>`;
        links += `<p style="color:#888; margin-top:10px;">Bei Fragen: WhatsApp 0176-46657268</p>`;
        
        document.getElementById('download-links').innerHTML = links;
        document.getElementById('downloadModal').classList.add('active');
    }, 4000);
}

const sparten = {
    ignition: { title: '🔥 IGNITION', badgeClass: 'ignition' },
    momentum: { title: '⚡ MOMENTUM', badgeClass: 'momentum' },
    ascent: { title: '🚀 ASCENT', badgeClass: 'ascent' },
    sovereign: { title: '👑 SOVEREIGN', badgeClass: 'sovereign' },
    omega: { title: '💎 OMEGA', badgeClass: 'omega' }
};

const container = document.getElementById('stufen-container');
for (const [key, meta] of Object.entries(sparten)) {
    const items = stufen.filter(s => s.sparte === key);
    const section = document.createElement('section');
    section.id = 'sparte-' + key;
    section.className = 'section';
    let gridHTML = `<h2>${meta.title}</h2><div class="grid">`;
    items.forEach(s => {
        let priceHTML = s.price.replace('/J','<small> €/Jahr</small>').replace('/Tag','<small> €/Tag</small>').replace('/h','<small> €/h</small>');
        if (!priceHTML.includes('<small>')) priceHTML = s.price + '<small> €</small>';
        gridHTML += `
            <div class="card ${s.featured ? 'featured' : ''}">
                <span class="badge ${s.featured ? 'gold' : meta.badgeClass}">${s.name.split(' –')[0]}</span>
                <h3>${s.name}</h3><p class="desc">${s.desc}</p>
                <p class="price">${priceHTML}</p>
                <ul class="features">${s.features.map(f => `<li>${f}</li>`).join('')}</ul>
                <button class="btn" onclick="kaufeJetzt('${s.name}', '${priceHTML}')">Jetzt kaufen</button>
            </div>
        `;
    });
    gridHTML += `</div>`;
    section.innerHTML = gridHTML;
    container.appendChild(section);
}
</script>
</body>
</html>
</html>
